#!/bin/bash
# Pre-push hook: runs build, lint, format check, and tests before allowing push
set -e

ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"

echo ""
echo "  [pre-push] Running prechecks before push..."
echo ""

# Build
echo "  [1/5] Building..."
npm run build > /dev/null 2>&1
echo "        ✔ Build passed"

# Lint
echo "  [2/5] Linting..."
npx eslint src/ --max-warnings=0 2>/dev/null || {
  # Allow warnings but not errors
  LINT_EXIT=$(npx eslint src/ 2>&1)
  if echo "$LINT_EXIT" | grep -q "error"; then
    echo "        ✖ Lint errors found. Fix before pushing."
    exit 1
  fi
}
echo "        ✔ Lint passed"

# Format
echo "  [3/5] Auto-formatting..."
npm run format > /dev/null 2>&1
# Check if formatting changed anything (shouldn't if pre-commit ran)
if [[ -n "$(git status --porcelain)" ]]; then
  echo "        ⚠ Files were reformatted. Staging changes..."
  git add -u
fi
echo "        ✔ Formatting OK"

# Tests (unit + e2e)
echo "  [4/5] Running tests..."
npm run test:ci > /dev/null 2>&1
echo "        ✔ Tests passed"

echo ""
echo "  ✔ All prechecks passed. Pushing..."
echo ""
