#!/bin/bash
# Auto-version and changelog after commit
# Runs on all branches (main, feature/MR branches, merged MRs)
# Skips if last commit is already a version bump (prevents loop)
set -e

LAST_MSG=$(git log -1 --pretty=format:"%s")

# Prevent infinite loop
if echo "$LAST_MSG" | grep -q "^chore(release):"; then
  exit 0
fi

# Skip on detached HEAD (e.g., CI checkout, tag builds)
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
if [ -z "$BRANCH" ]; then
  exit 0
fi

ROOT=$(git rev-parse --show-toplevel)
PKG="$ROOT/package.json"
CHANGELOG="$ROOT/CHANGELOG.md"

# Get current version
CURRENT=$(node -p "require('$PKG').version")
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT"

# Determine bump from commit message
BUMP="patch"
if echo "$LAST_MSG" | grep -qi "BREAKING"; then
  BUMP="major"
elif echo "$LAST_MSG" | grep -qE "^feat(\(|:)"; then
  BUMP="minor"
fi

# Bump
case "$BUMP" in
  major) MAJOR=$((MAJOR+1)); MINOR=0; PATCH=0 ;;
  minor) MINOR=$((MINOR+1)); PATCH=0 ;;
  patch) PATCH=$((PATCH+1)) ;;
esac
NEW_VERSION="$MAJOR.$MINOR.$PATCH"

# Update package.json
sed -i '' "s/\"version\": \"$CURRENT\"/\"version\": \"$NEW_VERSION\"/" "$PKG"

# Build changelog entry
DATE=$(date '+%Y-%m-%d')
CLEAN=$(echo "$LAST_MSG" | sed -E 's/^(feat|fix|chore|refactor|docs|style|perf|test)(\([^)]*\))?:\s*//')

if echo "$LAST_MSG" | grep -qE "^feat(\(|:)"; then
  SECTION="### Added"
elif echo "$LAST_MSG" | grep -qE "^fix(\(|:)"; then
  SECTION="### Fixed"
else
  SECTION="### Changed"
fi

ENTRY="## [$NEW_VERSION] — $DATE\n\n$SECTION\n- $CLEAN\n"

# Insert into CHANGELOG
if [ ! -f "$CHANGELOG" ]; then
  printf "# Changelog\n\n%b\n" "$ENTRY" > "$CHANGELOG"
else
  HEADER_END=$(grep -n "^## \[" "$CHANGELOG" | head -1 | cut -d: -f1)
  if [ -n "$HEADER_END" ]; then
    HEAD_CONTENT=$(head -n $((HEADER_END-1)) "$CHANGELOG")
    TAIL_CONTENT=$(tail -n +$HEADER_END "$CHANGELOG")
    printf "%s\n\n%b\n%s\n" "$HEAD_CONTENT" "$ENTRY" "$TAIL_CONTENT" > "$CHANGELOG"
  else
    printf "\n%b" "$ENTRY" >> "$CHANGELOG"
  fi
fi

# Commit version bump
git add "$PKG" "$CHANGELOG"
git commit --no-verify -m "chore(release): $NEW_VERSION"

# Auto-tag for npm publish
git tag "v$NEW_VERSION"

echo "📦 Auto-versioned: $CURRENT → $NEW_VERSION ($BUMP) on branch $BRANCH"
